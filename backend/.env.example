# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/appaammas_pickles?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
SPRING_DATASOURCE_USERNAME=pickles
SPRING_DATASOURCE_PASSWORD=picklespass

# JWT (HS256 — must be at least 32 chars / 256 bits)
APP_JWT_SECRET=change-me-in-production-this-must-be-at-least-32-chars-long
APP_JWT_EXPIRATION_MS=86400000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
